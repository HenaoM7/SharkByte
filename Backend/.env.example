# ============================================
# Backend API — Variables de Entorno
# Copiar como .env y completar los valores
# ============================================

# Puerto del servidor
PORT=3000

# MongoDB
MONGO_URI=mongodb://admin:password@localhost:27017/eco_nodo?authSource=admin

# JWT
JWT_SECRET=cambiar_por_secreto_muy_largo_y_aleatorio_minimo_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=cambiar_por_otro_secreto_diferente_minimo_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# Clave interna para llamadas de n8n al Backend (sin JWT)
INTERNAL_API_KEY=cambiar_por_clave_interna_segura

# Entorno
NODE_ENV=development
