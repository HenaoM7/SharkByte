{
  "name": "sharkbyte-backend",
  "version": "1.0.0",
  "description": "SharkByte SaaS Backend API — Government layer for multi-tenant WhatsApp automation",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --selectProjects unit",
    "test:e2e": "jest --selectProjects e2e --runInBand --forceExit",
    "test:all": "jest --runInBand --forceExit",
    "test:cov": "jest --selectProjects unit --coverage",
    "test:watch": "jest --selectProjects unit --watch"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.997.0",
    "@aws-sdk/s3-request-presigner": "^3.997.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/mongoose": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/swagger": "^7.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@types/helmet": "^0.0.48",
    "@types/multer": "^2.0.0",
    "@types/nodemailer": "^7.0.10",
    "@types/uuid": "^10.0.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "helmet": "^8.1.0",
    "mercadopago": "^2.12.0",
    "mongoose": "^8.0.0",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "mongodb-memory-server": "^10.4.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.module.ts",
      "!src/main.ts"
    ],
    "coverageDirectory": "coverage",
    "testEnvironment": "node",
    "projects": [
      {
        "displayName": "unit",
        "testMatch": [
          "<rootDir>/src/**/*.spec.ts"
        ],
        "transform": {
          "^.+\\.(t|j)s$": "ts-jest"
        },
        "testEnvironment": "node"
      },
      {
        "displayName": "e2e",
        "testMatch": [
          "<rootDir>/test/**/*.e2e-spec.ts"
        ],
        "transform": {
          "^.+\\.(t|j)s$": "ts-jest"
        },
        "testEnvironment": "node"
      }
    ]
  }
}
