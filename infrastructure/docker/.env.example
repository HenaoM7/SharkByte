# ============================================================
# SharkByte — Variables de Entorno para Docker Compose
# ============================================================
# 1. Copiar este archivo: cp .env.example .env
# 2. Reemplazar TODOS los valores con tus datos reales
# 3. Nunca commitear el archivo .env al repositorio
#
# Generar passwords seguros:  openssl rand -hex 16
# Generar secrets largos:     openssl rand -base64 64
# ============================================================

# ─── MongoDB ───────────────────────────────────────────────
# PRODUCCIÓN: Usar password aleatorio largo
MONGO_USERNAME=sharkbyte
MONGO_PASSWORD=CAMBIAR_EN_PRODUCCION

# ─── Mongo Express (panel web de MongoDB) ──────────────────
# PRODUCCIÓN: Solo accesible vía perfil debug (docker compose --profile debug up)
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=CAMBIAR_EN_PRODUCCION

# ─── n8n ───────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=CAMBIAR_EN_PRODUCCION
# Dominio de n8n (usado por N8N_HOST en docker-compose.prod.yml)
N8N_DOMAIN=n8n.sharkbyteia.com
# URL pública completa de n8n para webhooks
# DESARROLLO: http://localhost:5678/
# PRODUCCIÓN: https://n8n.sharkbyteia.com/
WEBHOOK_URL=https://n8n.sharkbyteia.com/
# Clave de cifrado para credenciales guardadas en n8n — NO cambiar una vez configurado
# Generar: openssl rand -hex 32
N8N_ENCRYPTION_KEY=CAMBIAR_EN_PRODUCCION

# ─── n8n PostgreSQL (BD interna de n8n) ────────────────────
N8N_DB_USER=n8n
N8N_DB_PASSWORD=CAMBIAR_EN_PRODUCCION

# ─── Backend NestJS ────────────────────────────────────────
# URL del Backend accesible desde n8n (Docker → host)
# Linux: funciona con extra_hosts: host.docker.internal:host-gateway en docker-compose.prod.yml
BACKEND_URL=http://host.docker.internal:3000
# REQUERIDO: Debe coincidir con INTERNAL_API_KEY en Backend/.env
# Generar: openssl rand -hex 32
BACKEND_INTERNAL_KEY=CAMBIAR_EN_PRODUCCION

# ─── Evolution API (WhatsApp) ──────────────────────────────
# URL interna del servicio Evolution (dentro de la red Docker)
EVOLUTION_API_URL=http://eco_evolution:8080
# URL pública de Evolution API (para QR codes y webhooks externos)
# PRODUCCIÓN: https://api.sharkbyteia.com
EVOLUTION_SERVER_URL=https://api.sharkbyteia.com
# API Key global de Evolution — protege todos los endpoints
# REQUERIDO: Generar aleatorio — openssl rand -hex 32
EVOLUTION_API_KEY=CAMBIAR_EN_PRODUCCION

# ─── Base de datos Evolution (PostgreSQL) ──────────────────
EVOLUTION_DB_USER=evolution
EVOLUTION_DB_PASSWORD=CAMBIAR_EN_PRODUCCION

# ─── OpenAI / IA ───────────────────────────────────────────
# REQUERIDO: Los workflows de n8n no funcionan sin esto
OPENAI_API_KEY=sk-proj-...

# ============================================================
# Variables SOLO del Backend (Backend/.env) — referencia
# ============================================================
# Las siguientes variables van en Backend/.env, NO aquí.
# Se incluyen como referencia para no olvidarlas al desplegar:
#
# PORT=3000
# NODE_ENV=production
# MONGO_URI=mongodb://sharkbyte:PASS@localhost:27017/eco_nodo?authSource=admin
#
# Generar con: openssl rand -base64 64
# JWT_SECRET=<secreto_fuerte>
# JWT_REFRESH_SECRET=<secreto_diferente_al_anterior>
# JWT_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN=7d
#
# Debe coincidir con BACKEND_INTERNAL_KEY de este .env
# INTERNAL_API_KEY=<mismo_valor_que_BACKEND_INTERNAL_KEY>
#
# FRONTEND_URL=https://app.sharkbyteia.com
#
# Evolution (mismos valores que arriba)
# EVOLUTION_API_URL=http://localhost:8080
# EVOLUTION_API_KEY=<mismo valor que EVOLUTION_API_KEY>
# EVOLUTION_API_URL_INTERNAL=http://eco_evolution:8080
# N8N_WEBHOOK_URL=http://eco_n8n:5678/webhook/whatsapp-inbound
#
# DigitalOcean Spaces (imágenes de productos + PDFs de catálogo)
# DO_SPACES_KEY=<access_key>
# DO_SPACES_SECRET=<secret_key>
# DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
# DO_SPACES_BUCKET=sharkbyte
# DO_SPACES_CDN_URL=https://sharkbyte.nyc3.cdn.digitaloceanspaces.com
#
# Stripe (facturación)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_ENTERPRISE=price_...
