# ============================================
# ECONODO — .gitignore
# ============================================

# Variables de entorno (NUNCA subir al repositorio)
.env
.env.local
.env.production
*.env

# Excepción: plantillas de ejemplo SÍ se suben
!.env.example

# ============================================
# NODE / JAVASCRIPT
# ============================================
node_modules/
dist/
build/
.next/
.nuxt/
out/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ============================================
# DOCKER
# ============================================
# Datos persistentes de Docker (generados localmente)
docker-data/
volumes/

# ============================================
# IDEs y EDITORES
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ============================================
# SEGURIDAD (CRÍTICO)
# ============================================
# Claves y certificados
*.pem
*.key
*.cert
*.p12
*.pfx
id_rsa
id_rsa.pub

# Archivos de credenciales
credentials.json
service-account.json
secrets.json

# ============================================
# n8n
# ============================================
# Workflows exportados con credenciales embedded
n8n/workflows/exports-with-credentials/

# ============================================
# BACKUPS
# ============================================
backups/
*.tar.gz
*.zip
*.dump

# ============================================
# TEMPORALES
# ============================================
tmp/
temp/
.tmp/
*.tmp

# ============================================
# SCRIPTS DE DEPLOY (credenciales hardcodeadas)
# ============================================
deploy.py
deploy2.py
deploy_channels.py
deploy_workflows.py
deploy_workflows_now.py
check_pm2.py
probe_auth.py
probe_routes.py
smoke_test.py
smoke_test_v2.py
launch_compass.ps1
debug_runner*.py
apply_*.py

# Archivos de auditoría y salidas temporales
audit_output.txt
audit_api_output.txt
audit_mongo_output.txt
pm2_status.txt
*.output
*_full.txt
*_parsed.json

# TypeScript build info
*.tsbuildinfo

# Scripts de deploy/audit internos (credenciales hardcodeadas)
scripts/
